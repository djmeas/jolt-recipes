{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "NITRO_HOST=0.0.0.0 NITRO_PORT=8385 node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:prepare": "node scripts/ensure-data-dir.mjs",
    "predb:migrate": "npm run db:prepare",
    "predev": "npm run db:prepare"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9"
  }
}
